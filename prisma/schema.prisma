// Family children incentive system schema
// Use PostgreSQL in production (Vercel + Neon, etc.). Local: Docker Postgres or Neon dev branch.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries (Neon: use the **pooled** host on Vercel).
  url       = env("DATABASE_URL")
  // Migrations need a **direct** session (advisory locks fail through PgBouncer pooler).
  // Neon dashboard → copy "Direct" connection string. Locally without a pooler, set = DATABASE_URL.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------- Members (parents / grandparents) ----------
model Member {
  id        String   @id @default(cuid())
  nameZh    String
  nameEn    String
  role      String // "parent" | "grandparent" | "other"
  emoji     String   @default("👤")
  color     String   @default("#6366f1")
  pinHash   String? // optional 4-digit PIN; null means no PIN protection
  createdAt DateTime @default(now())

  logs               LogEntry[]
  userAccount        UserAccount?
  redemptionRequests RewardRedemption[] @relation("RedemptionRequester")
  redemptionReviews  RewardRedemption[] @relation("RedemptionReviewer")
}

// ---------- Children ----------
model Child {
  id        String    @id @default(cuid())
  nameZh    String
  nameEn    String
  emoji     String    @default("🧒")
  color     String    @default("#3b82f6") // accent for charts
  birthday  DateTime?
  order     Int       @default(0)
  archived  Boolean   @default(false)
  createdAt DateTime  @default(now())

  categories  Category[]
  logs        LogEntry[]
  userAccount UserAccount?
  rewards     Reward[]
  redemptions RewardRedemption[]
}

// ---------- Login accounts (parents / children) ----------
model UserAccount {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  /**
   * parent_admin = manage behaviors + accounts; parent = score only; child = read-only overview
   */
  accountKind  String
  memberId     String?  @unique
  member       Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  childId      String?  @unique
  child        Child?   @relation(fields: [childId], references: [id], onDelete: Cascade)
  disabled     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([memberId])
  @@index([childId])
}

// ---------- Categories per child ----------
model Category {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  key       String // stable slug like "resilience"
  nameZh    String
  nameEn    String
  emoji     String   @default("✨")
  order     Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  behaviors Behavior[]

  @@unique([childId, key])
  @@index([childId])
}

// ---------- Specific behaviors (positive ☆ or negative △) ----------
model Behavior {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  type       String // "positive" | "negative"
  nameZh     String
  nameEn     String
  // Points are stored as positive number; sign is implied by type.
  // E.g. positive type with points=2 -> +2; negative type with points=2 -> -2.
  points     Int      @default(1)
  order      Int      @default(0)
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())

  logs LogEntry[]

  @@index([categoryId])
}

// ---------- Daily log entries ----------
model LogEntry {
  id          String   @id @default(cuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  behaviorId  String
  behavior    Behavior @relation(fields: [behaviorId], references: [id], onDelete: Cascade)
  // Denormalized type/points snapshot to keep history stable even if behavior changes later.
  type        String // "positive" | "negative"
  points      Int // signed value already applied (positive or negative)
  occurrences Int      @default(1)
  date        DateTime // local-day boundary (stored as midnight UTC for that local date)
  notes       String?
  createdById String?
  createdBy   Member?  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([childId, date])
  @@index([behaviorId])
}

// ---------- Reward catalog (things kids can spend points on) ----------
// Scope: childId == null  → available to every child (shared catalog).
//        childId == "X"   → only that child can redeem this reward.
model Reward {
  id           String   @id @default(cuid())
  childId      String?
  child        Child?   @relation(fields: [childId], references: [id], onDelete: Cascade)
  nameZh       String
  nameEn       String
  descZh       String?
  descEn       String?
  emoji        String   @default("🎁")
  /**
   * Cost in points. Always positive integer.
   */
  costPoints   Int
  /**
   * Logical bucket the kid sees as a tab. e.g. treat | privilege | outing | toy | family | learning
   */
  category     String   @default("treat")
  /**
   * null = unlimited; integer = remaining stock that decrements on approve.
   */
  stock        Int?
  /**
   * Optional cooldown so the same reward can't be redeemed every day.
   */
  cooldownDays Int?
  order        Int      @default(0)
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  redemptions RewardRedemption[]

  @@index([childId])
  @@index([category])
}

// ---------- Redemption events (the "wallet ledger" for spending) ----------
// status flow: pending → (approved | rejected | cancelled)
//              approved → fulfilled
model RewardRedemption {
  id            String    @id @default(cuid())
  rewardId      String
  reward        Reward    @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  childId       String
  child         Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  /**
   * Snapshot of cost at the moment of request, so later admin edits don't change history.
   */
  costPoints    Int
  status        String    @default("pending") // pending | approved | fulfilled | rejected | cancelled
  notes         String?
  /**
   * Member who requested. null = the child themselves requested.
   */
  requestedById String?
  requestedBy   Member?   @relation("RedemptionRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  /**
   * Member who approved/rejected/fulfilled.
   */
  reviewedById  String?
  reviewedBy    Member?   @relation("RedemptionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  fulfilledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([childId, status])
  @@index([rewardId])
  @@index([status, createdAt])
}
